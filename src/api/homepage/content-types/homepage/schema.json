{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Manage frontend home content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "heroTitle": { "type": "string", "required": true },
    "heroSubtitle": { "type": "string" },
    "heroImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "heroCtaText": { "type": "string", "default": "Solicitar Presupuesto" },
    "heroCtaLink": { "type": "string", "default": "/contact" },
    "aboutTitle": { "type": "string" },
    "aboutContent": { "type": "richtext" },
    "statsYears": { "type": "integer", "default": 15 },
    "statsProjects": { "type": "integer", "default": 500 }
  }
}
